PORT=3000

# TMDB API - Get free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE=https://image.tmdb.org/t/p

# TheSportsDB - Free, no key needed for basic (key for premium)
SPORTSDB_BASE_URL=https://www.thesportsdb.com/api/v1/json
SPORTSDB_API_KEY=3

# API-Football - Free tier at https://www.api-football.com (optional)
API_FOOTBALL_KEY=your_api_football_key_here
API_FOOTBALL_BASE=https://v3.football.api-sports.io

# Cache TTL in seconds
CACHE_TTL_SHORT=300
CACHE_TTL_MEDIUM=1800
CACHE_TTL_LONG=86400

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
